# Copy to .env and change every secret before any real deployment.
NODE_ENV=development
PORT=8430

# Secrets — the server refuses to start in production with the dev defaults.
JWT_SECRET=dev-only-change-me
ORACLE_SECRET=dev-only-change-me
PHONE_SALT=dev-only-change-me

# OTP delivery. 'console' logs the code and echoes it to the app (dev only —
# the server refuses to start with it in production). 'termii' sends real SMS
# via termii.com: sign up, fund the account, and paste the API key here.
SMS_PROVIDER=console
TERMII_API_KEY=
TERMII_SENDER_ID=N-Alert
TERMII_CHANNEL=dnd
# 'telegram' provider (free): create a bot with @BotFather, then run
#   node scripts/telegram_setup.js https://your-domain
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# Owner "master" number — gets a Telegram ping for EVERY site activity
# (verification/report/mapping/subscription). Must link its Telegram once, like
# any observer. Leave blank to disable. Nigerian format, e.g. 08031234567.
MASTER_PHONE=+2348167000004


# IReV cross-check — set when INEC opens the election on inecelectionresults.ng:
# IREV_ELECTION_ID = the election's _id from GET
#   https://dolphin-app-sleqh.ondigitalocean.app/api/v1/elections
# IREV_CONTEST = which Hawkeye contest it corresponds to (PRES/SEN/REP/GOV/SHA).
IREV_ELECTION_ID=
IREV_CONTEST=PRES

# Rig-proofing knobs
GEOFENCE_RADIUS_M=200
MAX_GPS_ACCURACY_M=100
CLUSTER_RADIUS_M=150
MIN_LOCATION_REPORTS=3
PHOTO_GPS_COHERENCE_M=750
PHOTO_MAX_AGE_S=600
DHASH_HAMMING_THRESHOLD=4
MIN_REPORTS_FOR_VERIFIED=3
MIN_CONFIDENCE_FOR_VERIFIED=66
OTP_TTL_S=600
ORIGIN_AUTH_SECRET=            # optional: origin lock — must match the Cloudflare Transform Rule header

# Cloudflare scoped API Token (NOT Global API Key) — perms: Zone>Cache Purge, DNS>Read.
# For deploy cache-purge + DNS/tunnel checks only. Security/bot settings stay dashboard-only.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
